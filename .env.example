# GraceNote / TMS headend configuration
GN_HEADEND = "lineupId"
GN_LINEUP = "USA-lineupId-DEFAULT"
GN_COUNTRY = "USA"
GN_ZIPCODE = "00000"
GN_LANGUAGE = "en"
GN_DEVICE = "-"

# TMDB read-access token (optional — enables poster images and metadata)
# Get one at https://www.themoviedb.org/settings/api
TMDB_TOKEN = ""

# Base URL of the server (optional — rewrites image URLs in XMLTV to use the
# built-in image proxy cache instead of hitting remote hosts directly)
# Example: http://192.168.1.50:8080
BASE_URL = ""
